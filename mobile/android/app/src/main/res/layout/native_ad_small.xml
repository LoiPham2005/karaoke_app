<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ad_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/ad_padding"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ad_app_icon"
            android:layout_width="@dimen/ad_icon_small"
            android:layout_height="@dimen/ad_icon_small"
            android:scaleType="centerCrop"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/ad_icon_text_gap"
            android:layout_marginEnd="@dimen/ad_section_gap">

            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/ad_headline_small"
                style="@style/AdHeadline"/>

            <TextView
                android:id="@+id/ad_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/ad_body_small"
                android:layout_marginTop="@dimen/ad_text_gap"
                style="@style/AdBody"/>

        </LinearLayout>

        <Button
            android:id="@+id/ad_call_to_action"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/ad_cta_height_small"
            android:paddingHorizontal="@dimen/ad_cta_padding_h"
            android:textSize="@dimen/ad_cta_text_small"
            style="@style/AdCtaButton"/>

    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
