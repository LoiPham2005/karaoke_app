<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ad_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: icon + title + advertiser -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/ad_padding"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ad_app_icon"
                android:layout_width="@dimen/ad_icon_medium"
                android:layout_height="@dimen/ad_icon_medium"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/ad_icon_text_gap">

                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/ad_headline_medium"
                    style="@style/AdHeadline"/>

                <TextView
                    android:id="@+id/ad_advertiser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/ad_advertiser_text"
                    android:layout_marginTop="@dimen/ad_text_gap"
                    style="@style/AdTextSecondary"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Media image — chiếm phần còn lại -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Body text -->
        <TextView
            android:id="@+id/ad_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/ad_body_medium"
            android:paddingHorizontal="@dimen/ad_padding"
            android:paddingTop="@dimen/ad_section_gap"
            style="@style/AdBody"/>

        <!-- CTA button -->
        <Button
            android:id="@+id/ad_call_to_action"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ad_cta_height_medium"
            android:layout_margin="@dimen/ad_padding"
            android:textSize="@dimen/ad_cta_text_medium"
            style="@style/AdCtaButton"/>

    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
