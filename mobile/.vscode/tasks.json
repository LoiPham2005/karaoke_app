{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "buildEnv",
      "type": "pickString",
      "description": "Flavor",
      "options": ["dev", "stg", "prod"],
      "default": "dev"
    },
    {
      "id": "buildRunnerAction",
      "type": "pickString",
      "description": "Build Runner action",
      "options": [
        { "label": "Build — one-shot", "value": "build" },
        { "label": "Watch — continuous", "value": "watch" }
      ],
      "default": "build"
    },
    {
      "id": "l10nAction",
      "type": "pickString",
      "description": "Localization action",
      "options": [
        { "label": "Generate — flutter gen-l10n", "value": "fvm flutter gen-l10n" },
        { "label": "Sync — translate & sync ARB", "value": "fvm dart run tools/l10n_sync.dart --translate" },
        { "label": "Sync & Gen — full pipeline", "value": "fvm dart run tools/l10n_sync.dart --translate && fvm flutter gen-l10n" }
      ],
      "default": "fvm flutter gen-l10n"
    },
    {
      "id": "assetAction",
      "type": "pickString",
      "description": "Assets & Resources action",
      "options": [
        { "label": "flutter_gen — generate asset references", "value": "fluttergen -c pubspec.yaml" },
        { "label": "Bloc Helpers — generate bloc boilerplate", "value": "fvm dart run tools/generate_bloc_helper.dart" },
        { "label": "App Icons — flutter_launcher_icons", "value": "fvm flutter pub run flutter_launcher_icons" },
        { "label": "Native Splash — flutter_native_splash", "value": "fvm flutter pub run flutter_native_splash:create" }
      ],
      "default": "fluttergen -c pubspec.yaml"
    },
    {
      "id": "routeInfoAction",
      "type": "pickString",
      "description": "Route info action",
      "options": [
        { "label": "List — all routes", "value": "--list" },
        { "label": "Scan — analyze routes", "value": "--scan" }
      ],
      "default": "--list"
    },
    {
      "id": "routeName",
      "type": "promptString",
      "description": "Route class name (e.g. ProfileRoute)",
      "default": "ProfileRoute"
    },
    {
      "id": "routePath",
      "type": "promptString",
      "description": "URL path (e.g. /profile)",
      "default": "/profile"
    },
    {
      "id": "routePage",
      "type": "promptString",
      "description": "Page widget class (e.g. ProfilePage)",
      "default": "ProfilePage"
    },
    {
      "id": "routeImport",
      "type": "promptString",
      "description": "Import path from lib/ (e.g. features/profile/presentation/pages/profile_page.dart)",
      "default": "features/profile/presentation/pages/profile_page.dart"
    },
    {
      "id": "routeGroup",
      "type": "pickString",
      "description": "Route group in app_routes.dart",
      "options": ["Auth", "Main", "Product", "Cart & Orders"],
      "default": "Main"
    },
    {
      "id": "maintenanceAction",
      "type": "pickString",
      "description": "Maintenance action",
      "options": [
        { "label": "Pub Get", "value": "fvm flutter pub get" },
        { "label": "Clean & Get", "value": "fvm flutter clean && fvm flutter pub get" },
        { "label": "Pub Upgrade (major versions)", "value": "fvm flutter pub upgrade --major-versions" },
        { "label": "Full Regenerate — clean → get → l10n → bloc → build_runner", "value": "fvm flutter clean && fvm flutter pub get && fvm flutter gen-l10n && fvm dart run tools/generate_bloc_helper.dart && fvm dart run build_runner build --delete-conflicting-outputs" }
      ],
      "default": "fvm flutter pub get"
    },
    {
      "id": "qualityAction",
      "type": "pickString",
      "description": "Quality action",
      "options": [
        { "label": "Analyze & Fix", "value": "fvm flutter analyze && fvm dart fix --apply" },
        { "label": "Format Code", "value": "fvm dart format ." },
        { "label": "Flutter Doctor", "value": "fvm flutter doctor -v" }
      ],
      "default": "fvm flutter analyze && fvm dart fix --apply"
    },
    {
      "id": "testAction",
      "type": "pickString",
      "description": "Test action",
      "options": [
        { "label": "Run Tests", "value": "fvm flutter test" },
        { "label": "Coverage (lcov → html)", "value": "fvm flutter test --coverage && genhtml coverage/lcov.info -o coverage/html" }
      ],
      "default": "fvm flutter test"
    },
    {
      "id": "fvmInfoAction",
      "type": "pickString",
      "description": "FVM info action",
      "options": [
        { "label": "List — installed versions", "value": "list" },
        { "label": "Releases — available flutter releases", "value": "releases" },
        { "label": "Global — show global config", "value": "global" }
      ],
      "default": "list"
    },
    {
      "id": "fvmVersionAction",
      "type": "pickString",
      "description": "FVM version action",
      "options": ["use", "install", "remove"],
      "default": "use"
    },
    {
      "id": "flutterVersion",
      "type": "promptString",
      "description": "Flutter version (e.g. 3.27.3, stable)",
      "default": "stable"
    },
    {
      "id": "newPackageName",
      "type": "promptString",
      "description": "New package name",
      "default": "flutter_base"
    },
    {
      "id": "newAppLabel",
      "type": "promptString",
      "description": "New app display name",
      "default": "Flutter App"
    },
    {
      "id": "masonBrick",
      "type": "pickString",
      "description": "Chọn loại Feature brick",
      "options": [
        { "label": "🏗️  Feature Cổ Điển  (Data + Domain + Presentation)", "value": "feature_co_dien" },
        { "label": "⚡ Feature Rút Gọn  (Không có Domain layer)", "value": "feature_rut_gon" },
        { "label": "🔗 Feature Kết Hợp  (List + Card + Detail)", "value": "feature_ket_hop" },
        { "label": "🔗 Feature Rút Gọn  (Gen)", "value": "feature_rut_gon_gen" },
        { "label": "🔗 Feature Rút Gọn  (Thủ Công)", "value": "feature_rut_gon_thu_cong" }
      ],
      "default": "feature_rut_gon_gen"
    }
  ],
  "tasks": [
    // ── 🚀 BUILD & RUN ───────────────────────────────────────────
    {
      "label": "🚀 Run: Debug",
      "type": "shell",
      "command": "fvm flutter run --flavor ${input:buildEnv} -t lib/main_${input:buildEnv}.dart",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🚀 Run: Dev",
      "type": "shell",
      "command": "fvm flutter run --flavor dev -t lib/main_dev.dart",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🚀 Run: Stg",
      "type": "shell",
      "command": "fvm flutter run --flavor stg -t lib/main_stg.dart",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🚀 Run: Prod",
      "type": "shell",
      "command": "fvm flutter run --flavor prod -t lib/main_prod.dart --release",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "⚡ Build Runner: Build",
      "type": "shell",
      "command": "fvm dart run build_runner build --delete-conflicting-outputs",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "👁️ Build Runner: Watch",
      "type": "shell",
      "command": "fvm dart run build_runner watch --delete-conflicting-outputs",
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🧹 Clean & Get",
      "type": "shell",
      "command": "fvm flutter clean && fvm flutter pub get",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "📦 Pub Get",
      "type": "shell",
      "command": "fvm flutter pub get",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "✨ Format",
      "type": "shell",
      "command": "fvm dart format .",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "🔍 Analyze & Fix",
      "type": "shell",
      "command": "fvm flutter analyze && fvm dart fix --apply",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "🌐 Generate l10n",
      "type": "shell",
      "command": "fvm flutter gen-l10n",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "🔄 Full Regenerate",
      "type": "shell",
      "command": "fvm flutter clean && fvm flutter pub get && fvm flutter gen-l10n && fvm dart run build_runner build --delete-conflicting-outputs",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🚀 Build: APK",
      "type": "shell",
      "command": "fvm flutter build apk --flavor ${input:buildEnv} -t lib/main_${input:buildEnv}.dart --release",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🚀 Build: AAB",
      "type": "shell",
      "command": "fvm flutter build appbundle --flavor ${input:buildEnv} -t lib/main_${input:buildEnv}.dart --release",
      "group": "build"
    },
    {
      "label": "🍎 Build: iOS  ⚠️ macOS + Xcode only",
      "type": "shell",
      "command": "fvm flutter build ios --flavor ${input:buildEnv} -t lib/main_${input:buildEnv}.dart --release",
      "group": "build"
    },
    // ── ⚡ CODE GENERATION ───────────────────────────────────────
    {
      "label": "⚡ Build Runner",
      "type": "shell",
      "command": "fvm dart run build_runner ${input:buildRunnerAction} --delete-conflicting-outputs",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🌐 Localization (l10n)",
      "type": "shell",
      "osx": { "command": "bash -c \"${input:l10nAction}\"" },
      "linux": { "command": "bash -c \"${input:l10nAction}\"" },
      "windows": { "command": "cmd /c \"${input:l10nAction}\"" },
      "group": "build"
    },
    {
      "label": "📦 Assets & Resources",
      "type": "shell",
      "osx": { "command": "bash -c \"${input:assetAction}\"" },
      "linux": { "command": "bash -c \"${input:assetAction}\"" },
      "windows": { "command": "cmd /c \"${input:assetAction}\"" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    // ── 🛣️ ROUTE ─────────────────────────────────────────────────
    {
      "label": "🛣️ Route: Info",
      "type": "shell",
      "command": "fvm dart run tools/generate_route.dart ${input:routeInfoAction}",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "🛣️ Route: Generate New",
      "type": "shell",
      "command": "fvm dart run tools/generate_route.dart --name ${input:routeName} --path ${input:routePath} --page ${input:routePage} --import ${input:routeImport} --group ${input:routeGroup}",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    // ── 🧹 MAINTENANCE ───────────────────────────────────────────
    {
      "label": "🧹 Maintenance",
      "type": "shell",
      "osx": { "command": "bash -c \"${input:maintenanceAction}\"" },
      "linux": { "command": "bash -c \"${input:maintenanceAction}\"" },
      "windows": { "command": "cmd /c \"${input:maintenanceAction}\"" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    // ── 🔧 QUALITY ───────────────────────────────────────────────
    {
      "label": "🔧 Quality",
      "type": "shell",
      "osx": { "command": "bash -c \"${input:qualityAction}\"" },
      "linux": { "command": "bash -c \"${input:qualityAction}\"" },
      "windows": { "command": "cmd /c \"${input:qualityAction}\"" },
      "group": "build"
    },
    // ── 🧪 TESTING ───────────────────────────────────────────────
    {
      "label": "🧪 Testing",
      "type": "shell",
      "osx": { "command": "bash -c \"${input:testAction}\"" },
      "linux": { "command": "bash -c \"${input:testAction}\"" },
      "windows": { "command": "cmd /c \"${input:testAction}\"" },
      "group": "test"
    },
    // ── ⚙️ FVM ───────────────────────────────────────────────────
    {
      "label": "⚙️ FVM: Info",
      "type": "shell",
      "command": "fvm ${input:fvmInfoAction}",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "⚙️ FVM: Version",
      "type": "shell",
      "command": "fvm ${input:fvmVersionAction} ${input:flutterVersion}",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    // ── 🛠️ REFACTORING ───────────────────────────────────────────
    {
      "label": "🔧 Rename: Package Name",
      "type": "shell",
      "windows": {
        "command": "powershell -Command \"$oldName = (Get-Content pubspec.yaml | Select-String -Pattern '^name: ' | ForEach-Object { $_.Line.Split(':')[1].Trim() }); Write-Host 'Renaming' $oldName '->' '${input:newPackageName}'; (Get-Content pubspec.yaml) -replace ('name: ' + $oldName), ('name: ${input:newPackageName}') | Set-Content pubspec.yaml; Get-ChildItem -Recurse -Include *.dart | ForEach-Object { (Get-Content $_.FullName) -replace ('package:' + $oldName), 'package:${input:newPackageName}' | Set-Content $_.FullName }; fvm flutter clean; fvm flutter pub get\""
      },
      "osx": {
        "command": "bash -c \"OLD=$(grep '^name: ' pubspec.yaml | sed 's/name: //'); echo Renaming $OLD to ${input:newPackageName}; sed -i '' \\\"s/name: $OLD/name: ${input:newPackageName}/\\\" pubspec.yaml; find lib -name '*.dart' -exec sed -i '' \\\"s|package:$OLD|package:${input:newPackageName}|g\\\" {} +; fvm flutter clean && fvm flutter pub get\""
      },
      "linux": {
        "command": "bash -c \"OLD=$(grep '^name: ' pubspec.yaml | sed 's/name: //'); echo Renaming $OLD to ${input:newPackageName}; sed -i \\\"s/name: $OLD/name: ${input:newPackageName}/\\\" pubspec.yaml; find lib -name '*.dart' -exec sed -i \\\"s|package:$OLD|package:${input:newPackageName}|g\\\" {} +; fvm flutter clean && fvm flutter pub get\""
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🏷️ Rename: App Label",
      "type": "shell",
      "command": "fvm flutter pub run rename setAppName --value \"${input:newAppLabel}\"",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    // ── 🧱 MASON ─────────────────────────────────────────────────
    {
      "label": "🧱 Mason: Generate Feature",
      "type": "shell",
      "command": "mason make ${input:masonBrick} --on-conflict overwrite",
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    }
  ]
}
