// ════════════════════════════════════════════════════════════════
// Project Keybindings — chỉ active khi mở workspace này
// Tham khảo: tasks.json → label phải khớp chính xác
// ════════════════════════════════════════════════════════════════
[
  // ── 🚀 RUN APP (theo flavor) ───────────────────────────────────
  {
    "key": "f6",
    "command": "workbench.action.tasks.runTask",
    "args": "🚀 Run: Dev"
  },
  {
    "key": "shift+f6",
    "command": "workbench.action.tasks.runTask",
    "args": "🚀 Run: Stg"
  },
  {
    "key": "ctrl+shift+f6",
    "command": "workbench.action.tasks.runTask",
    "args": "🚀 Run: Prod"
  },

  // ── ⚡ CODE GENERATION ─────────────────────────────────────────
  {
    "key": "ctrl+shift+r",
    "command": "workbench.action.tasks.runTask",
    "args": "⚡ Build Runner: Build"
  },
  {
    "key": "ctrl+shift+w",
    "command": "workbench.action.tasks.runTask",
    "args": "👁️ Build Runner: Watch"
  },
  {
    "key": "ctrl+alt+l",
    "command": "workbench.action.tasks.runTask",
    "args": "🌐 Generate l10n"
  },

  // ── 🧹 MAINTENANCE ─────────────────────────────────────────────
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.tasks.runTask",
    "args": "🧹 Clean & Get"
  },
  {
    "key": "ctrl+alt+g",
    "command": "workbench.action.tasks.runTask",
    "args": "📦 Pub Get"
  },
  {
    "key": "ctrl+shift+g",
    "command": "workbench.action.tasks.runTask",
    "args": "🔄 Full Regenerate"
  },

  // ── 🔧 QUALITY ────────────────────────────────────────────────
  {
    "key": "ctrl+alt+f",
    "command": "workbench.action.tasks.runTask",
    "args": "✨ Format"
  },
  {
    "key": "ctrl+alt+a",
    "command": "workbench.action.tasks.runTask",
    "args": "🔍 Analyze & Fix"
  },

  // ── 🧱 MASON ──────────────────────────────────────────────────
  {
    "key": "ctrl+alt+m",
    "command": "workbench.action.tasks.runTask",
    "args": "🧱 Mason: Generate Feature"
  },

  // ── 🛣️ ROUTE GEN ──────────────────────────────────────────────
  {
    "key": "ctrl+alt+r",
    "command": "workbench.action.tasks.runTask",
    "args": "🛣️ Route: Generate New"
  }
]
