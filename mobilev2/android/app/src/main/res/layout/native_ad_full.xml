<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout cho native ad FULL-SCREEN — MediaView chiếm hết space còn lại,
  text + CTA dồn xuống đáy màn hình.
  Bind data trong NativeAdFactoryFull.kt.
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ad_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Media (image / video) — chiếm phần lớn màn hình -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop" />

        <!-- Bottom panel: icon + headline + body + CTA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Icon + headline + advertiser + Ad badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ad_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/ad_advertiser"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ad_text_tertiary"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ad_badge_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="Ad"
                    android:textColor="@color/ad_badge_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Body -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ad_text_secondary"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Call-to-action button — to + nổi bật ở cuối màn -->
            <Button
                android:id="@+id/ad_call_to_action"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/ad_cta_button"
                android:textColor="@color/ad_cta_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textAllCaps="true" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
